# =============================================================================
# intel_collector - Environment Configuration
# =============================================================================
# 1. Copy this file to .env:  cp .env.example .env
# 2. Fill in your API keys. Leave empty to disable a source automatically.
# 3. Add .env to .gitignore! Never commit real credentials.
# =============================================================================

# ── Free & Community APIs ────────────────────────────────────────────────────

# GreyNoise: https://community.greynoise.io/
GREYNOISE_API_KEY=

# LeakIX: https://leakix.net/
LEAKIX_API_KEY=

# Netlas: https://app.netlas.io/
NETLAS_API_KEY=

# Pulsedive: https://pulsedive.com/
PULSEDIVE_API_KEY=

# Shodan: https://account.shodan.io/
SHODAN_API_KEY=

# Stalkphish: https://www.stalkphish.io/
STALKPHISH_API_KEY=

# Triage: https://tria.ge/
TRIAGE_API_KEY=

# URLHaus: https://urlhaus-api.abuse.ch/v2
URLHAUS_API_KEY=

# URLScan: https://urlscan.io/
URLSCAN_API_KEY=

# VirusTotal: https://www.virustotal.com/
VIRUSTOTAL_API_KEY=

# ── Enterprise / Paid APIs ──────────────────────────────────────────────────
# CrowdStrike Falcon: https://falcon.crowdstrike.com/
CRWD_CLIENT_ID=
CRWD_CLIENT_SECRET=

# Emerging Threats: https://www.emergingthreats.net/
ETINTEL_API_KEY=

# Filescan.io: https://filescan.io/
FILESCAN_API_KEY=

# Hybrid Analysis: https://www.hybrid-analysis.com/
HYBRID_API_KEY=

# Microsoft Defender for Endpoint (Azure AD App Registration)
# Required scopes: https://api.securitycenter.windows.com/.default
MSDE_TENANT_ID=
MSDE_CLIENT_ID=
MSDE_CLIENT_SECRET=